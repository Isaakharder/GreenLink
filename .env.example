# Supabase project settings (from Project Settings > API).
# Only the anon/public key belongs in the frontend. NEVER put the service_role key here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# GOLFCOURSE_API_KEY is NOT a frontend/VITE_ variable -- it's a Supabase
# Edge Function secret, used only by supabase/functions/golf-course-lookup.
# Set it with `supabase secrets set GOLFCOURSE_API_KEY=...`, never here.
# See supabase/functions/golf-course-lookup/README.md.
